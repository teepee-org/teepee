{
  "name": "teepee-server",
  "version": "0.3.0",
  "description": "HTTP and WebSocket server for Teepee.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc && node scripts/prepare-web-dist.cjs",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run"
  },
  "homepage": "https://teepee.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/typeeffect/teepee.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "teepee-core": "^0.3.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
